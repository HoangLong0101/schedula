{
  "name": "schedula-functions",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "seed:mock": "node scripts/seedMockData.js",
    "seed:verify": "node scripts/verifySeedData.js",
    "data:audit": "node scripts/auditDataConsistency.js",
    "data:sync": "node scripts/syncTenantData.js",
    "data:aggregate": "node scripts/buildAggregateStats.js",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^7.0.1"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
